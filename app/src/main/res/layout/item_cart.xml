<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/cartProductImage"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="#F4F2F1"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@tools:sample/backgrounds/scenic" />

    <TextView
        android:id="@+id/cartProductName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="#222222"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/cartRemoveButton"
        app:layout_constraintStart_toEndOf="@id/cartProductImage"
        app:layout_constraintTop_toTopOf="@id/cartProductImage"
        tools:text="Кардиган из хлопка" />

    <ImageButton
        android:id="@+id/cartRemoveButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/remove_cart_item"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/cartProductImage"
        app:tint="#B6B6B6" />

    <TextView
        android:id="@+id/cartProductSize"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        android:textColor="#8E8E8E"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@id/cartRemoveButton"
        app:layout_constraintStart_toEndOf="@id/cartProductImage"
        app:layout_constraintTop_toBottomOf="@id/cartProductName"
        tools:text="XXL" />

    <TextView
        android:id="@+id/cartProductPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:textColor="#6D3F2E"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/cartProductImage"
        app:layout_constraintStart_toEndOf="@id/cartProductImage"
        tools:text="14 999 ₽" />

    <LinearLayout
        android:id="@+id/cartQuantityControls"
        android:layout_width="96dp"
        android:layout_height="36dp"
        android:background="#F7F7F7"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="@id/cartProductImage"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/cartDecreaseButton"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/decrease_quantity"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#111111" />

        <TextView
            android:id="@+id/cartQuantityText"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textColor="#6D3F2E"
            android:textSize="15sp"
            tools:text="1" />

        <ImageButton
            android:id="@+id/cartIncreaseButton"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/increase_quantity"
            android:src="@android:drawable/ic_input_add"
            app:tint="#111111" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
